<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ row.ticker }} — {{ row.company_name }}</title>
<style>
body { font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Arial, sans-serif; max-width: 820px; margin: 0 auto; padding: 32px 24px; color: #1a1a1a; background: #fafafa; line-height: 1.5; }
.header { border-bottom: 2px solid #1a1a1a; padding-bottom: 12px; margin-bottom: 20px; }
.ticker { font-size: 32px; font-weight: 700; margin: 0; letter-spacing: -0.02em; }
.company { font-size: 15px; color: #666; margin: 4px 0 0 0; }
.meta { font-size: 13px; color: #888; margin-top: 8px; }
.stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 10px; margin: 20px 0; }
.stat { background: #fff; padding: 12px 14px; border-radius: 6px; border: 1px solid #e5e5e5; }
.stat-label { font-size: 11px; color: #888; text-transform: uppercase; letter-spacing: 0.05em; }
.stat-value { font-size: 18px; font-weight: 600; margin-top: 4px; }
.green { color: #0a8040; } .red { color: #c22; }
h2 { font-size: 15px; margin-top: 28px; margin-bottom: 10px; color: #333; text-transform: uppercase; letter-spacing: 0.05em; }
.section { background: #fff; padding: 16px 18px; border-radius: 6px; border: 1px solid #e5e5e5; }
.news-item, .action-item { padding: 8px 0; border-bottom: 1px solid #f0f0f0; font-size: 14px; }
.news-item:last-child, .action-item:last-child { border-bottom: none; }
.news-date, .action-date { color: #888; font-size: 12px; margin-right: 8px; font-variant-numeric: tabular-nums; }
a { color: #0066cc; text-decoration: none; }
a:hover { text-decoration: underline; }
.footer { margin-top: 32px; padding-top: 16px; border-top: 1px solid #e5e5e5; font-size: 12px; color: #999; }
</style>
</head>
<body>

<div class="header">
  <h1 class="ticker">{{ row.ticker }}</h1>
  <p class="company">{{ row.company_name }}</p>
  <div class="meta">{{ row.sector }} · Needham analyst: <strong>{{ row.analyst }}</strong> · <a href="https://finance.yahoo.com/quote/{{ row.ticker }}" target="_blank" style="color: #0066cc; font-weight: 600;">View live on Yahoo Finance →</a></div>
</div>

<div class="stats">
  <div class="stat"><div class="stat-label">Price</div><div class="stat-value">{% if row.price is number %}${{ "%.2f" | format(row.price) }}{% else %}—{% endif %}</div></div>
  <div class="stat"><div class="stat-label">1-day</div><div class="stat-value {% if row.pct_1d is number and row.pct_1d > 0 %}green{% elif row.pct_1d is number and row.pct_1d < 0 %}red{% endif %}">{% if row.pct_1d is number %}{{ "%+.2f" | format(row.pct_1d) }}%{% else %}—{% endif %}</div></div>
  <div class="stat"><div class="stat-label">5-day</div><div class="stat-value {% if row.pct_5d is number and row.pct_5d > 0 %}green{% elif row.pct_5d is number and row.pct_5d < 0 %}red{% endif %}">{% if row.pct_5d is number %}{{ "%+.2f" | format(row.pct_5d) }}%{% else %}—{% endif %}</div></div>
  <div class="stat"><div class="stat-label">Next earnings</div><div class="stat-value" style="font-size: 15px;">{{ row.next_earnings or "—" }}</div></div>
  <div class="stat"><div class="stat-label">Consensus</div><div class="stat-value" style="font-size: 15px;">{{ row.consensus or "—" }}{% if row.n_analysts %} <span style="font-size: 12px; color: #888; font-weight: normal;">({{ row.n_analysts }})</span>{% endif %}</div></div>
  <div class="stat"><div class="stat-label">Avg target</div><div class="stat-value">{% if row.price_target is number %}${{ "%.2f" | format(row.price_target) }}{% if row.upside_pct is number %} <span style="font-size: 12px;" class="{% if row.upside_pct > 0 %}green{% else %}red{% endif %}">{{ "%+.1f" | format(row.upside_pct) }}%</span>{% endif %}{% else %}—{% endif %}</div></div>
</div>

{% if row.description %}
<h2>Business</h2>
<div class="section" style="font-size: 14px; color: #333;">{{ row.description }}</div>
{% endif %}

{% if row.news %}
<h2>Recent news</h2>
<div class="section">
{% for n in row.news %}
  <div class="news-item">
    <span class="news-date">{{ n.date }}</span>
    <a href="{{ n.link }}" target="_blank">{{ n.title }}</a>
    {% if n.publisher %}<span style="color: #999; font-size: 12px;"> · {{ n.publisher }}</span>{% endif %}
  </div>
{% endfor %}
</div>
{% endif %}

{% if row.upgrades %}
<h2>Recent rating actions</h2>
<div class="section">
{% for u in row.upgrades %}
  <div class="action-item">
    <span class="action-date">{{ u.date }}</span>
    <strong>{{ u.firm or "—" }}</strong>
    {% if u.from and u.to %}<span style="color: #666;"> · {{ u.from }} → {{ u.to }}</span>
    {% elif u.to %}<span style="color: #666;"> · {{ u.to }}</span>{% endif %}
    {% if u.action %}<span style="color: #999; font-size: 12px;"> · {{ u.action }}</span>{% endif %}
  </div>
{% endfor %}
</div>
{% endif %}

<div class="footer">
  Data via yfinance (Yahoo Finance). Page regenerated each weekday AM/PM. · <a href="../index.html">← Full universe</a>
</div>

</body>
</html>
