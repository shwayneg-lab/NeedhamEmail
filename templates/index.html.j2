<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Needham Coverage Universe</title>
<style>
body { font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Arial, sans-serif; max-width: 1100px; margin: 0 auto; padding: 32px 24px; color: #1a1a1a; line-height: 1.5; }
h1 { margin: 0 0 4px 0; font-size: 28px; letter-spacing: -0.02em; }
.meta { color: #666; margin-bottom: 24px; font-size: 14px; }
h2 { font-size: 12px; color: #666; text-transform: uppercase; letter-spacing: 0.05em; margin-top: 28px; padding-bottom: 4px; border-bottom: 1px solid #e5e5e5; }
.grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 4px 16px; font-size: 14px; margin-top: 8px; }
.item { padding: 2px 0; }
a { color: #0066cc; text-decoration: none; font-weight: 600; font-variant-numeric: tabular-nums; }
a:hover { text-decoration: underline; }
</style>
</head>
<body>
<h1>Needham Coverage Universe</h1>
<div class="meta">{{ rows | length }} names across {{ rows | map(attribute="sector") | unique | list | length }} sectors · <a href="latest.html">View latest digest</a></div>

{% set by_sector = {} %}
{% for r in rows %}{% set _ = by_sector.setdefault(r.sector or "—", []).append(r) %}{% endfor %}

{% for sector, items in by_sector | dictsort %}
<h2>{{ sector }} <span style="color: #aaa; font-weight: normal;">({{ items | length }})</span></h2>
<div class="grid">
{% for r in items | sort(attribute="ticker") %}
  <div class="item"><a href="tickers/{{ r.ticker }}.html">{{ r.ticker }}</a></div>
{% endfor %}
</div>
{% endfor %}
</body>
</html>
