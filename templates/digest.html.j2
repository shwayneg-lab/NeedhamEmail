<!DOCTYPE html>
<html>
<head><meta charset="utf-8"><title>Needham Digest</title></head>
<body style="font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Arial, sans-serif; max-width: 680px; margin: 0 auto; color: #1a1a1a; background: #fff; padding: 24px; line-height: 1.5;">

<h1 style="font-size: 22px; margin: 0 0 4px 0;">Needham Coverage Digest</h1>
<div style="color: #666; font-size: 13px; margin-bottom: 24px;">
  {{ "Morning" if mode == "morning" else "Close" }} · {{ now.strftime("%A, %B %d, %Y") }}
</div>

<h2 style="font-size: 16px; border-bottom: 1px solid #eee; padding-bottom: 6px; margin-top: 24px;">Today's watchlist</h2>
{% if watchlist %}
<table cellpadding="0" cellspacing="0" style="width: 100%; border-collapse: collapse; font-size: 14px;">
{% for item in watchlist %}
  <tr>
    <td style="padding: 8px 8px 8px 0; vertical-align: top; white-space: nowrap;">
      <a href="{{ pages_base }}/tickers/{{ item.ticker }}.html" style="color: #0066cc; font-weight: 600; text-decoration: none;">{{ item.ticker }}</a>
    </td>
    <td style="padding: 8px 0; color: #333;">
      {{ item.company_name }} <span style="color: #999;">· {{ item.sector }} · {{ item.analyst }}</span><br>
      <span style="color: #666; font-size: 13px;">{{ item.reasons | join(" · ") }}</span>
    </td>
  </tr>
{% endfor %}
</table>
{% else %}
<p style="color: #999; font-size: 14px; margin: 8px 0;">Nothing flagged.</p>
{% endif %}

<h2 style="font-size: 16px; border-bottom: 1px solid #eee; padding-bottom: 6px; margin-top: 28px;">Biggest movers (5-day)</h2>
<table cellpadding="0" cellspacing="0" style="width: 100%; font-size: 14px;">
  <tr>
    <td style="vertical-align: top; width: 50%; padding-right: 12px;">
      <div style="color: #0a8040; font-weight: 600; font-size: 12px; letter-spacing: 0.05em; margin-bottom: 8px;">TOP GAINERS</div>
{% for m in movers.gainers %}
      <div style="padding: 4px 0;">
        <a href="{{ pages_base }}/tickers/{{ m.ticker }}.html" style="color: #0066cc; font-weight: 600; text-decoration: none;">{{ m.ticker }}</a>
        <span style="color: #0a8040;">+{{ "%.1f" | format(m.pct_5d) }}%</span>
        <span style="color: #999; font-size: 12px;">· {{ m.sector }}</span>
      </div>
{% endfor %}
    </td>
    <td style="vertical-align: top; width: 50%;">
      <div style="color: #c22; font-weight: 600; font-size: 12px; letter-spacing: 0.05em; margin-bottom: 8px;">TOP DECLINERS</div>
{% for m in movers.decliners %}
      <div style="padding: 4px 0;">
        <a href="{{ pages_base }}/tickers/{{ m.ticker }}.html" style="color: #0066cc; font-weight: 600; text-decoration: none;">{{ m.ticker }}</a>
        <span style="color: #c22;">{{ "%.1f" | format(m.pct_5d) }}%</span>
        <span style="color: #999; font-size: 12px;">· {{ m.sector }}</span>
      </div>
{% endfor %}
    </td>
  </tr>
</table>

<h2 style="font-size: 16px; border-bottom: 1px solid #eee; padding-bottom: 6px; margin-top: 28px;">Earnings this week</h2>
{% if earnings %}
<table cellpadding="0" cellspacing="0" style="width: 100%; border-collapse: collapse; font-size: 14px;">
{% for e in earnings %}
  <tr>
    <td style="padding: 6px 8px 6px 0; white-space: nowrap; color: #555; font-size: 13px; width: 90px; vertical-align: top;">{{ e.next_earnings }}</td>
    <td style="padding: 6px 0;">
      <a href="{{ pages_base }}/tickers/{{ e.ticker }}.html" style="color: #0066cc; font-weight: 600; text-decoration: none;">{{ e.ticker }}</a>
      {{ e.company_name }}
      <span style="color: #999; font-size: 13px;">· {{ e.analyst }}</span>
    </td>
  </tr>
{% endfor %}
</table>
{% else %}
<p style="color: #999; font-size: 14px; margin: 8px 0;">No covered names reporting in the next 5 trading days.</p>
{% endif %}

{% if new_actions %}
<h2 style="font-size: 16px; border-bottom: 1px solid #eee; padding-bottom: 6px; margin-top: 28px;">Street actions (since last digest)</h2>
<table cellpadding="0" cellspacing="0" style="width: 100%; border-collapse: collapse; font-size: 14px;">
{% for a in new_actions %}
  <tr>
    <td style="padding: 6px 8px 6px 0; white-space: nowrap; color: #555; font-size: 13px; width: 90px; vertical-align: top;">{{ a.date }}</td>
    <td style="padding: 6px 0;">
      <a href="{{ pages_base }}/tickers/{{ a.ticker }}.html" style="color: #0066cc; font-weight: 600; text-decoration: none;">{{ a.ticker }}</a>
      <span style="color: #333;">{{ a.firm }}</span>
      {% if a.from and a.to %}<span style="color: #666;">· {{ a.from }} → {{ a.to }}</span>
      {% elif a.to %}<span style="color: #666;">· {{ a.to }}</span>{% endif %}
      {% if a.action %}<span style="color: #999; font-size: 12px;">· {{ a.action }}</span>{% endif %}
    </td>
  </tr>
{% endfor %}
</table>
{% endif %}

<div style="margin-top: 32px; padding-top: 16px; border-top: 1px solid #eee; color: #999; font-size: 12px;">
  Generated {{ now.strftime("%Y-%m-%d %H:%M %Z") }} · <a href="{{ pages_base }}/index.html" style="color: #999;">Full universe →</a>
</div>

</body>
</html>
